public class ScenarioEventStore {

    private final List<ScenarioEvent> events = new CopyOnWriteArrayList<>();

    public void record(String topic, String correlationId, Object payload) {
        events.add(new ScenarioEvent(topic, correlationId, payload));
    }

    public void reset() {
        events.clear();
    }

    public <T> List<T> find(Class<T> type) {
        return events.stream()
                .map(ScenarioEvent::payload)
                .filter(type::isInstance)
                .map(type::cast)
                .toList();
    }

    public <T> List<T> findByCorrelation(Class<T> type, String correlationId) {
        return events.stream()
                .filter(e -> correlationId.equals(e.correlationId()))
                .map(ScenarioEvent::payload)
                .filter(type::isInstance)
                .map(type::cast)
                .toList();
    }

    public int size() {
        return events.size();
    }

    public List<ScenarioEvent> all() {
        return List.copyOf(events);
    }
}
